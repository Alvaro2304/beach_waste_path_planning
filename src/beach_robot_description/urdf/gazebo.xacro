<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>front_left_joint</left_joint>
      <left_joint>rear_left_joint</left_joint>
      <right_joint>front_right_joint</right_joint>
      <right_joint>rear_right_joint</right_joint>
      <wheel_separation>${2*track_y}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
    </plugin>
  </gazebo>

  <!-- ============================================================== -->
  <!--  IMU — BNO055 on sand terrain (harsh / realistic profile)       -->
  <!-- ============================================================== -->
  <!-- Datasheet-nominal (clean lab) values, kept for comparison:       -->
  <!--   gyro  stddev = 0.0024 rad/s  (0.014 deg/s/sqrt(Hz) * sqrt(100))-->
  <!--   accel stddev = 0.015 m/s^2   (150 ug/sqrt(Hz) * g * sqrt(100)) -->
  <!--                                                                  -->
  <!-- Harsh values below assume:                                       -->
  <!--   - rigid chassis on irregular sand (high-freq vibration)        -->
  <!--   - small motors near IMU (EMI / magnetic disturbance)           -->
  <!--   - slow bias drift typical of MEMS gyros                        -->
  <!-- ============================================================== -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <topic>imu/data</topic>
      <gz_frame_id>imu_link</gz_frame_id>
      <imu>
        <angular_velocity>
          <!-- ~2x datasheet stddev + slow bias drift for sand vibration -->
          <x><noise type="gaussian">
            <mean>0.0</mean><stddev>0.005</stddev>
            <bias_mean>0.000</bias_mean><bias_stddev>0.000</bias_stddev>
            <dynamic_bias_stddev>0.0</dynamic_bias_stddev>
            <dynamic_bias_correlation_time>1000.0</dynamic_bias_correlation_time>
          </noise></x>
          <y><noise type="gaussian">
            <mean>0.0</mean><stddev>0.005</stddev>
            <bias_mean>0.000</bias_mean><bias_stddev>0.000</bias_stddev>
            <dynamic_bias_stddev>0.0</dynamic_bias_stddev>
            <dynamic_bias_correlation_time>1000.0</dynamic_bias_correlation_time>
          </noise></y>
          <z><noise type="gaussian">
            <mean>0.0</mean><stddev>0.005</stddev>
            <bias_mean>0.000</bias_mean><bias_stddev>0.000</bias_stddev>
            <dynamic_bias_stddev>0.0</dynamic_bias_stddev>
            <dynamic_bias_correlation_time>1000.0</dynamic_bias_correlation_time>
          </noise></z>
        </angular_velocity>
        <linear_acceleration>
          <!-- ~6x datasheet stddev: sand bumps dominate, not electronics -->
          <x><noise type="gaussian">
            <mean>0.0</mean><stddev>0.1</stddev>
            <bias_mean>0.0</bias_mean><bias_stddev>0.0</bias_stddev>
            <dynamic_bias_stddev>0.0</dynamic_bias_stddev>
            <dynamic_bias_correlation_time>300.0</dynamic_bias_correlation_time>
          </noise></x>
          <y><noise type="gaussian">
            <mean>0.0</mean><stddev>0.1</stddev>
            <bias_mean>0.0</bias_mean><bias_stddev>0.0</bias_stddev>
            <dynamic_bias_stddev>0.0</dynamic_bias_stddev>
            <dynamic_bias_correlation_time>300.0</dynamic_bias_correlation_time>
          </noise></y>
          <z><noise type="gaussian">
            <mean>0.0</mean><stddev>0.1</stddev>
            <bias_mean>0.0</bias_mean><bias_stddev>0.0</bias_stddev>
            <dynamic_bias_stddev>0.0</dynamic_bias_stddev>
            <dynamic_bias_correlation_time>300.0</dynamic_bias_correlation_time>
          </noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

  <!-- ============================================================== -->
  <!--  GPS — u-blox NEO-8M on open-sky beach                         -->
  <!-- ============================================================== -->
  <!-- Datasheet: 2.5 m CEP horizontal (= stddev 2.12 m).             -->
  <!-- Kept at 2.5 m real-world because beach GPS also suffers from:   -->
  <!--   - multipath from wet sand / water surface                     -->
  <!--   - occasional signal dropouts near dunes                       -->
  <!--                                                                  -->
  <!-- IMPORTANT: gz-sim-navsat applies <horizontal> noise stddev      -->
  <!-- directly in DEGREES of latitude/longitude, not meters.           -->
  <!-- Conversion: 1 degree of latitude ~= 111 320 m.                   -->
  <!--   2.5 m   -> 2.5 / 111320  ~= 2.25e-5 deg                        -->
  <!-- Vertical is in meters (altitude), keep as-is.                    -->
  <!-- ============================================================== -->
  <gazebo reference="gps_link">
    <sensor name="gps_sensor" type="navsat">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <topic>gps/fix</topic>
      <gz_frame_id>gps_link</gz_frame_id>
      <navsat>
        <position_sensing>
          <horizontal><noise type="gaussian"><mean>0</mean><stddev>2.25e-5</stddev></noise></horizontal>
          <vertical><noise type="gaussian"><mean>0</mean><stddev>5.0</stddev></noise></vertical>
        </position_sensing>
      </navsat>
    </sensor>
  </gazebo>

  <gazebo reference="base_link">
    <material>Gazebo/Orange</material>
  </gazebo>

  <xacro:macro name="wheel_material" params="link_name">
    <gazebo reference="${link_name}">
      <material>Gazebo/Black</material>
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
    </gazebo>
  </xacro:macro>

  <xacro:wheel_material link_name="front_left_link"/>
  <xacro:wheel_material link_name="front_right_link"/>
  <xacro:wheel_material link_name="rear_left_link"/>
  <xacro:wheel_material link_name="rear_right_link"/>

</robot>
